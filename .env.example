VITE_SMART_CLIENT_ID=cerner_client_id
VITE_DEMO_FHIR_BASE_URL=https://r4.smarthealthit.org
# Optional. Leave unset to auto-select launch scope:
# - Provider EHR Launch: patient/Patient.read patient/Encounter.read patient/DiagnosticReport.read patient/ServiceRequest.read patient/Binary.read launch openid fhirUser
# - Patient Standalone Launch: patient/Patient.read patient/Encounter.read patient/DiagnosticReport.read patient/ServiceRequest.read patient/Binary.read launch/patient online_access openid profile
# VITE_SMART_SCOPE=patient/Patient.read patient/Encounter.read patient/DiagnosticReport.read patient/ServiceRequest.read patient/Binary.read launch/patient online_access openid profile

# Cross-domain radiology POC configuration.
# Domain 1 defaults to the SMART launch FHIR server if no URL is provided.
VITE_RADIOLOGY_DOMAIN_1_NAME=Millennium Domain 1
# VITE_RADIOLOGY_DOMAIN_1_URL=https://domain-one.example.com/fhir
# VITE_RADIOLOGY_DOMAIN_1_PATIENT_ID=

# Domain 2 must be configured for real cross-domain calls.
VITE_RADIOLOGY_DOMAIN_2_NAME=Millennium Domain 2
# VITE_RADIOLOGY_DOMAIN_2_URL=https://domain-two.example.com/fhir
# VITE_RADIOLOGY_DOMAIN_2_PATIENT_ID=

# Optional image viewer launch template. Supported placeholders:
# {studyId}, {orderId}, {accessToken}
# VITE_IMAGE_VIEWER_URL_TEMPLATE=https://viewer.example.com/launch?studyId={studyId}&orderId={orderId}
